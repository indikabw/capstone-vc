<?xml version="1.0"?>
<robot name="custom_bot" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- 
    Unified URDF combining TurtleBot4 and OpenManipulator-X
  -->

  <!-- 1. Include TurtleBot4 (Standard) -->
  <xacro:include filename="$(find custom_bot_description)/urdf/turtlebot4.urdf.xacro" />
  
  <!-- 2. Include OpenManipulator-X -->
  <xacro:include filename="$(find open_manipulator_description)/urdf/open_manipulator_x/open_manipulator_x_arm.urdf.xacro" />

  <!-- 3. Instantiate the OpenManipulator-X -->
  <xacro:open_manipulator_x prefix="omx_" />

  <!-- 4. Attach the arm to the TurtleBot4 -->
  <!-- We attach the base of the arm (omx_link1) to the TurtleBot4's top sensor plate -->
  <joint name="arm_mount_joint" type="fixed">
    <parent link="tower_sensor_plate"/> 
    <child link="omx_link1"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo plugins for OpenManipulator-X might need to be explicitly included if we want ROS2 control -->
  <xacro:include filename="$(find open_manipulator_description)/gazebo/open_manipulator_x.gazebo.xacro" />
  <xacro:open_manipulator_x_gazebo prefix="omx_" />

  <!-- 5. ROS2 Control for the arm in Gazebo -->
  <ros2_control name="open_manipulator_x_controller" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="omx_joint1">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="omx_joint2">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="omx_joint3">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="omx_joint4">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="omx_gripper_left_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="omx_gripper_right_joint">
      <param name="mimic">omx_gripper_left_joint</param>
      <param name="multiplier">1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- High friction for gripper links to prevent slipping -->
  <gazebo reference="omx_gripper_left_link">
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>
  
  <gazebo reference="omx_gripper_right_link">
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>

  <!-- Gazebo plugin to load ros2_control -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find custom_bot_description)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
